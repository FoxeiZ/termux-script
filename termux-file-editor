#!/data/data/com.termux/files/usr/bin/bash

if [ $# -eq 0 ]; then
    dialog --msgbox "Usage: termux-file-editor <file>" 8 40
    exit 1
fi

INPUT_FILE="$1"
BASENAME=$(basename "$INPUT_FILE")
NAME="${BASENAME%.*}"
EXT="${BASENAME##*.}"
CURRENT_DIR=$(pwd)
SCRIPT_DIR=$(dirname "$(readlink -f "$0")")
CONFIG_FILE="$SCRIPT_DIR/termux-file-editor.conf"
SAVE_CONFIG="1"

export DIALOG_OK=0
export DIALOG_CANCEL=10
export DIALOG_ESC=10
export DIALOG_ERROR=12
export DIALOG_TTY=1

DIALOG_STATUS=0
DIALOG_RESULT=""

run_dialog_capture() {
    DIALOG_RESULT=$(dialog "$@" 2>&1 >/dev/tty)
    DIALOG_STATUS=$?
}

is_dialog_back() {
    [ "$DIALOG_STATUS" -eq "$DIALOG_CANCEL" ]
}

is_dialog_error() {
    [ "$DIALOG_STATUS" -eq "$DIALOG_ERROR" ]
}

get_form_field() {
    echo "$1" | sed -n "${2}p"
}

if [ "$(uname -o)" = "Cygwin" ]; then
    termux-share() { cygstart "${@: -1}"; }
fi

# Check if file exists
if [ ! -f "$INPUT_FILE" ]; then
    dialog --msgbox "Error: File '$INPUT_FILE' not found!" 8 50
    exit 1
fi

load_config() {
    if [ -f "$CONFIG_FILE" ]; then
        # shellcheck source=/dev/null
        source "$CONFIG_FILE" 2>/dev/null || true
    fi
}

save_config() {
    local prefix="$1"
    shift
    local config_data="$*"
    
    if [ -f "$CONFIG_FILE" ]; then
        # Remove existing entries with the same prefix
        grep -v "^${prefix}_" "$CONFIG_FILE" > "${CONFIG_FILE}.tmp" 2>/dev/null || true
        mv "${CONFIG_FILE}.tmp" "$CONFIG_FILE" 2>/dev/null || true
    fi
    
    echo "$config_data" >> "$CONFIG_FILE"
}

# Function to compress file and share
compress_and_share() {
    
    # Set defaults from config or fallback values
    DEFAULT_FILENAME_TEMPLATE="${COMPRESS_FILENAME_TEMPLATE:-%name_%date.%ext}"
    DEFAULT_COMPRESSION_METHOD="${COMPRESS_COMPRESSION_METHOD:-7z}"
    DEFAULT_COMPRESSION_LEVEL="${COMPRESS_COMPRESSION_LEVEL:-5}"
    DEFAULT_PASSWORD="${COMPRESS_PASSWORD:-}"

    while true; do
        run_dialog_capture --clear --backtitle "Compress and Share" \
            --title "Compression Options" \
            --form "Configure compression settings:" 17 70 4 \
            "Filename template:" 1 1 "$DEFAULT_FILENAME_TEMPLATE" 1 20 40 0 \
            "Compression method:" 2 1 "$DEFAULT_COMPRESSION_METHOD" 2 20 10 0 \
            "Compression level (0-9):" 3 1 "$DEFAULT_COMPRESSION_LEVEL" 3 25 5 0 \
            "Password (optional):" 4 1 "$DEFAULT_PASSWORD" 4 20 30 0

        if is_dialog_back; then
            return
        fi
        if is_dialog_error; then
            dialog --msgbox "Error: Failed to open compression options dialog." 8 60
            return
        fi
        FORM_DATA="$DIALOG_RESULT"
        break
    done

    FILENAME_TEMPLATE=$(get_form_field "$FORM_DATA" 1)
    COMPRESSION_METHOD=$(get_form_field "$FORM_DATA" 2)
    COMPRESSION_LEVEL=$(get_form_field "$FORM_DATA" 3)
    PASSWORD=$(get_form_field "$FORM_DATA" 4)

    if [ "$SAVE_CONFIG" = "1" ]; then
        save_config "COMPRESS" "COMPRESS_FILENAME_TEMPLATE=\"$FILENAME_TEMPLATE\"
COMPRESS_COMPRESSION_METHOD=\"$COMPRESSION_METHOD\"
COMPRESS_COMPRESSION_LEVEL=\"$COMPRESSION_LEVEL\"
COMPRESS_PASSWORD=\"$PASSWORD\""
    fi

    CURRENT_DATE=$(date +"%Y%m%d_%H%M%S")
    OUTPUT_NAME="$FILENAME_TEMPLATE"
    OUTPUT_NAME="${OUTPUT_NAME//%name/$NAME}"
    OUTPUT_NAME="${OUTPUT_NAME//%date/$CURRENT_DATE}"
    OUTPUT_NAME="${OUTPUT_NAME//%original_ext/$EXT}"
    
    if [ "$COMPRESSION_METHOD" = "7z" ]; then
        OUTPUT_NAME="${OUTPUT_NAME//%ext/7z}"
        OUTPUT_FILE="$CURRENT_DIR/$OUTPUT_NAME"
    else
        OUTPUT_NAME="${OUTPUT_NAME//%ext/zip}"
        OUTPUT_FILE="$CURRENT_DIR/$OUTPUT_NAME"
    fi

    {
        echo "XXX"
        echo "0"
        echo "Starting compression..."
        echo "XXX"
        
        if [ -n "$PASSWORD" ]; then
            if [ "$COMPRESSION_METHOD" = "7z" ]; then
                7z a -mx="$COMPRESSION_LEVEL" -p"$PASSWORD" "$OUTPUT_FILE" "$INPUT_FILE" >/dev/null 2>&1
            else
                7z a -tzip -mx="$COMPRESSION_LEVEL" -p"$PASSWORD" "$OUTPUT_FILE" "$INPUT_FILE" >/dev/null 2>&1
            fi
        else
            if [ "$COMPRESSION_METHOD" = "7z" ]; then
                7z a -mx="$COMPRESSION_LEVEL" "$OUTPUT_FILE" "$INPUT_FILE" >/dev/null 2>&1
            else
                7z a -tzip -mx="$COMPRESSION_LEVEL" "$OUTPUT_FILE" "$INPUT_FILE" >/dev/null 2>&1
            fi
        fi
        
        echo "XXX"
        echo "50"
        echo "Compression completed. Preparing to share..."
        echo "XXX"
        
        sleep 1
        
        echo "XXX"
        echo "100"
        echo "Done!"
        echo "XXX"
    } | dialog --backtitle "Compress and Share" --title "Progress" --gauge "Please wait..." 10 70 0

    if [ -f "$OUTPUT_FILE" ]; then
        termux-share -a send "$OUTPUT_FILE"
        dialog --msgbox "File compressed and shared successfully!\nOutput: $OUTPUT_NAME" 8 60
    else
        dialog --msgbox "Error: Compression failed!" 8 40
    fi
}

reduce_and_share() {
    FILE_TYPE=$(file -b --mime-type "$INPUT_FILE" 2>/dev/null)
    
    case $FILE_TYPE in
        image/*)
            reduce_image_and_share
            ;;
        video/*)
            reduce_video_and_share
            ;;
        *)
            dialog --msgbox "Error: Unsupported media type. Only video and image files are supported." 8 60
            return
            ;;
    esac
}

reduce_video_and_share() {
    DURATION=$(ffprobe -v quiet -show_entries format=duration -of csv=p=0 "$INPUT_FILE" 2>/dev/null)
    ORIGINAL_SIZE=$(du -h "$INPUT_FILE" | cut -f1)
    ORIGINAL_RESOLUTION=$(ffprobe -select_streams v:0 -show_entries stream=width,height -of csv=s=x:p=0 "$INPUT_FILE" 2>/dev/null)

    DEFAULT_MAX_RESOLUTION="${VIDEO_MAX_RESOLUTION:-1280x720}"
    DEFAULT_TARGET_SIZE="${VIDEO_TARGET_SIZE:-0}"
    DEFAULT_MAX_FPS="${VIDEO_MAX_FPS:-0}"
    DEFAULT_AUDIO_BITRATE="${VIDEO_AUDIO_BITRATE:-128}"
    DEFAULT_VIDEO_CODEC="${VIDEO_VIDEO_CODEC:-h264}"
    DEFAULT_CRF_QUALITY="${VIDEO_CRF_QUALITY:-23}"
    DEFAULT_OUTPUT_TEMPLATE="${VIDEO_OUTPUT_TEMPLATE:-%name_reduced.%ext}"
    DEFAULT_START_TIME="${VIDEO_START_TIME:-}"
    DEFAULT_CUSTOM_FFMPEG_ARGS="${VIDEO_CUSTOM_FFMPEG_ARGS:-}"

    while true; do
        run_dialog_capture --clear --backtitle "Reduce Video and Share" \
            --title "FFmpeg Video Reduction Options" \
            --form "Configure video reduction settings:\nOriginal size: $ORIGINAL_SIZE\nOriginal resolution: $ORIGINAL_RESOLUTION" 32 80 9 \
            "Max resolution (e.g., 1280x720):" 1 1 "$DEFAULT_MAX_RESOLUTION" 1 35 20 0 \
            "Target file size (MB, 0=auto):" 2 1 "$DEFAULT_TARGET_SIZE" 2 35 10 0 \
            "Max FPS (0=keep original):" 3 1 "$DEFAULT_MAX_FPS" 3 35 10 0 \
            "Audio bitrate (0=no audio):" 4 1 "$DEFAULT_AUDIO_BITRATE" 4 35 10 0 \
            "Video codec:" 5 1 "$DEFAULT_VIDEO_CODEC" 5 35 15 0 \
            "CRF quality (18-32, lower=better):" 6 1 "$DEFAULT_CRF_QUALITY" 6 35 10 0 \
            "Output filename:" 7 1 "$DEFAULT_OUTPUT_TEMPLATE" 7 35 30 0 \
            "Start time (HH:MM:SS, optional):" 8 1 "$DEFAULT_START_TIME" 8 35 15 0 \
            "Custom FFmpeg args:" 9 1 "$DEFAULT_CUSTOM_FFMPEG_ARGS" 21 20 80 0

        if is_dialog_back; then
            return
        fi
        if is_dialog_error; then
            dialog --msgbox "Error: Failed to open video options dialog." 8 60
            return
        fi
        FORM_DATA="$DIALOG_RESULT"
        break
    done

    MAX_RESOLUTION=$(get_form_field "$FORM_DATA" 1)
    TARGET_SIZE=$(get_form_field "$FORM_DATA" 2)
    MAX_FPS=$(get_form_field "$FORM_DATA" 3)
    AUDIO_BITRATE=$(get_form_field "$FORM_DATA" 4)
    VIDEO_CODEC=$(get_form_field "$FORM_DATA" 5)
    CRF_QUALITY=$(get_form_field "$FORM_DATA" 6)
    OUTPUT_TEMPLATE=$(get_form_field "$FORM_DATA" 7)
    START_TIME=$(get_form_field "$FORM_DATA" 8)
    CUSTOM_FFMPEG_ARGS=$(get_form_field "$FORM_DATA" 9)

    if [ "$SAVE_CONFIG" = "1" ]; then
        save_config "VIDEO" "VIDEO_MAX_RESOLUTION=\"$MAX_RESOLUTION\"
VIDEO_TARGET_SIZE=\"$TARGET_SIZE\"
VIDEO_MAX_FPS=\"$MAX_FPS\"
VIDEO_AUDIO_BITRATE=\"$AUDIO_BITRATE\"
VIDEO_VIDEO_CODEC=\"$VIDEO_CODEC\"
VIDEO_CRF_QUALITY=\"$CRF_QUALITY\"
VIDEO_OUTPUT_TEMPLATE=\"$OUTPUT_TEMPLATE\"
VIDEO_START_TIME=\"$START_TIME\"
VIDEO_CUSTOM_FFMPEG_ARGS=\"$CUSTOM_FFMPEG_ARGS\""
    fi

    OUTPUT_NAME="$OUTPUT_TEMPLATE"
    OUTPUT_NAME="${OUTPUT_NAME//%name/$NAME}"
    OUTPUT_NAME="${OUTPUT_NAME//%ext/$EXT}"
    OUTPUT_FILE="$CURRENT_DIR/$OUTPUT_NAME"

    FFMPEG_ARGS=(-y)

    if [ -n "$START_TIME" ]; then
        FFMPEG_ARGS+=("-ss" "$START_TIME")
    fi

    FFMPEG_ARGS+=("-i" "$INPUT_FILE" "-c:v" "$VIDEO_CODEC")

    if [ "$MAX_RESOLUTION" != "0" ] && [ -n "$MAX_RESOLUTION" ]; then
        FFMPEG_ARGS+=("-vf" "scale=$MAX_RESOLUTION:force_original_aspect_ratio=decrease")
    fi

    if [ "$MAX_FPS" != "0" ] && [ -n "$MAX_FPS" ]; then
        FFMPEG_ARGS+=("-r" "$MAX_FPS")
    fi

    if [ "$AUDIO_BITRATE" = "0" ]; then
        FFMPEG_ARGS+=("-an")
    else
        FFMPEG_ARGS+=("-c:a" "aac" "-b:a" "${AUDIO_BITRATE}k")
    fi

    if [ "$TARGET_SIZE" != "0" ] && [ -n "$TARGET_SIZE" ] && [ -n "$DURATION" ]; then
        # Calculate target bitrate based on file size
        TARGET_BITRATE=$(echo "scale=0; ($TARGET_SIZE * 8192) / $DURATION" | bc 2>/dev/null)
        if [ -n "$TARGET_BITRATE" ] && [ "$TARGET_BITRATE" -gt 0 ]; then
            FFMPEG_ARGS+=("-b:v" "${TARGET_BITRATE}k" "-maxrate" "${TARGET_BITRATE}k" "-bufsize" "$((TARGET_BITRATE * 2))k")
        else
            FFMPEG_ARGS+=("-crf" "$CRF_QUALITY")
        fi
    else
        FFMPEG_ARGS+=("-crf" "$CRF_QUALITY")
    fi

    if [ -n "$CUSTOM_FFMPEG_ARGS" ]; then
        # shell-style splitting without eval
        read -r -a CUSTOM_FFMPEG_ARGS_ARRAY <<< "$CUSTOM_FFMPEG_ARGS"
        FFMPEG_ARGS+=("${CUSTOM_FFMPEG_ARGS_ARRAY[@]}")
    fi

    FFMPEG_ARGS+=("$OUTPUT_FILE")

    { ffmpeg "${FFMPEG_ARGS[@]}" 2>&1 ; } | dialog --progressbox 30 100

    if [ -f "$OUTPUT_FILE" ]; then
        NEW_SIZE=$(du -h "$OUTPUT_FILE" | cut -f1)
        termux-share -a send "$OUTPUT_FILE"
        dialog --msgbox "Video reduced and shared successfully!\nOriginal: $ORIGINAL_SIZE -> New: $NEW_SIZE\nOutput: $OUTPUT_NAME" 10 60
    else
        dialog --msgbox "Error: Video conversion failed!" 10 50
    fi
}

configure_image_options_jpeg() {
    while true; do
        run_dialog_capture --clear --backtitle "Reduce Image and Share" \
            --title "Image Options (JPEG)" \
            --form "Original size: $ORIGINAL_SIZE\nResolution: $IMAGE_INFO" 20 95 6 \
            "Max resolution (0=keep):" 1 1 "$DEFAULT_MAX_RESOLUTION" 1 34 20 0 \
            "Resize mode (fit/fill/stretch):" 2 1 "$DEFAULT_RESIZE_MODE" 2 34 20 0 \
            "Scale flags (lanczos/bicubic):" 3 1 "$DEFAULT_SCALE_FLAGS" 3 34 20 0 \
            "JPEG quality q:v (2-31):" 4 1 "$DEFAULT_JPEG_QUALITY" 4 34 10 0 \
            "JPEG subsampling (420/422/444):" 5 1 "$DEFAULT_JPEG_SUBSAMPLING" 5 34 8 0 \
            "Output filename:" 6 1 "$DEFAULT_OUTPUT_TEMPLATE" 6 34 40 0

        if is_dialog_back; then
            return 10
        fi
        if is_dialog_error; then
            dialog --msgbox "Error: Failed to open JPEG options dialog." 8 60
            return 1
        fi

        FORM_DATA="$DIALOG_RESULT"
        MAX_RESOLUTION=$(echo "$FORM_DATA" | sed -n '1p')
        RESIZE_MODE=$(echo "$FORM_DATA" | sed -n '2p')
        SCALE_FLAGS=$(echo "$FORM_DATA" | sed -n '3p')
        JPEG_QUALITY=$(echo "$FORM_DATA" | sed -n '4p')
        JPEG_SUBSAMPLING=$(echo "$FORM_DATA" | sed -n '5p')
        OUTPUT_TEMPLATE=$(echo "$FORM_DATA" | sed -n '6p')

        [ "$DEFAULT_STRIP_METADATA" = "1" ] && JPEG_STRIP_STATE="on" || JPEG_STRIP_STATE="off"
        [ "$DEFAULT_JPEG_PROGRESSIVE" = "1" ] && JPEG_PROGRESSIVE_STATE="on" || JPEG_PROGRESSIVE_STATE="off"
        [ "$DEFAULT_JPEG_OPTIMIZE" = "1" ] && JPEG_OPTIMIZE_STATE="on" || JPEG_OPTIMIZE_STATE="off"

        run_dialog_capture --clear --backtitle "Reduce Image and Share" \
            --title "JPEG Toggles" \
            --checklist "Enable or disable options:" 12 70 3 \
            "strip_metadata" "Strip metadata" "$JPEG_STRIP_STATE" \
            "jpeg_progressive" "Progressive JPEG" "$JPEG_PROGRESSIVE_STATE" \
            "jpeg_optimize" "Optimize Huffman tables" "$JPEG_OPTIMIZE_STATE"

        if is_dialog_back; then
            continue
        fi
        if is_dialog_error; then
            dialog --msgbox "Error: Failed to open JPEG toggles dialog." 8 60
            return 1
        fi

        JPEG_FLAGS="$DIALOG_RESULT"
        STRIP_METADATA="0"
        JPEG_PROGRESSIVE="0"
        JPEG_OPTIMIZE="0"

        case "$JPEG_FLAGS" in *"\"strip_metadata\""*) STRIP_METADATA="1" ;; esac
        case "$JPEG_FLAGS" in *"\"jpeg_progressive\""*) JPEG_PROGRESSIVE="1" ;; esac
        case "$JPEG_FLAGS" in *"\"jpeg_optimize\""*) JPEG_OPTIMIZE="1" ;; esac
        return 0
    done
}

