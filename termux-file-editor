reduce_image_and_share() {
    ORIGINAL_SIZE=$(du -h "$INPUT_FILE" | cut -f1)
    IMAGE_INFO=$(ffprobe -select_streams v:0 -show_entries stream=width,height -of csv=s=x:p=0 "$INPUT_FILE" 2>/dev/null)

    DEFAULT_OUTPUT_FORMAT="${IMAGE_OUTPUT_FORMAT:-jpeg}"
    DEFAULT_MAX_RESOLUTION="${IMAGE_MAX_RESOLUTION:-1280x720}"
    DEFAULT_RESIZE_MODE="${IMAGE_RESIZE_MODE:-fit}"
    DEFAULT_SCALE_FLAGS="${IMAGE_SCALE_FLAGS:-lanczos}"
    DEFAULT_STRIP_METADATA="${IMAGE_STRIP_METADATA:-1}"
    DEFAULT_OUTPUT_TEMPLATE="${IMAGE_OUTPUT_TEMPLATE:-%name_reduced.%ext}"

    DEFAULT_JPEG_QUALITY="${IMAGE_JPEG_QUALITY:-${IMAGE_GENERAL_QUALITY:-5}}"
    DEFAULT_JPEG_PROGRESSIVE="${IMAGE_JPEG_PROGRESSIVE:-1}"
    DEFAULT_JPEG_OPTIMIZE="${IMAGE_JPEG_OPTIMIZE:-1}"
    DEFAULT_JPEG_SUBSAMPLING="${IMAGE_JPEG_SUBSAMPLING:-420}"

    DEFAULT_PNG_COMPRESSION="${IMAGE_PNG_COMPRESSION:-${IMAGE_GENERAL_QUALITY:-5}}"
    DEFAULT_PNG_PRED="${IMAGE_PNG_PRED:-mixed}"
    DEFAULT_PNG_PALETTE_MODE="${IMAGE_PNG_PALETTE_MODE:-0}"

    DEFAULT_WEBP_QUALITY="${IMAGE_WEBP_QUALITY:-75}"
    DEFAULT_WEBP_LOSSLESS="${IMAGE_WEBP_LOSSLESS:-0}"
    DEFAULT_WEBP_COMPRESSION_LEVEL="${IMAGE_WEBP_COMPRESSION_LEVEL:-4}"
    DEFAULT_WEBP_PRESET="${IMAGE_WEBP_PRESET:-photo}"
    DEFAULT_WEBP_ALPHA_QUALITY="${IMAGE_WEBP_ALPHA_QUALITY:-80}"

    JPEG_STATE="off"
    PNG_STATE="off"
    WEBP_STATE="off"

    case "$DEFAULT_OUTPUT_FORMAT" in
        "jpeg") JPEG_STATE="on" ;;
        "png") PNG_STATE="on" ;;
        "webp") WEBP_STATE="on" ;;
        *) JPEG_STATE="on" ;;
    esac

    while true; do
        run_dialog_capture --clear --backtitle "Reduce Image and Share" \
            --title "Select Output Format" \
            --radiolist "Choose output format:" 12 50 3 \
            "jpeg" "JPEG (.jpg)" "$JPEG_STATE" \
            "png" "PNG (.png)" "$PNG_STATE" \
            "webp" "WebP (.webp)" "$WEBP_STATE"

        if is_dialog_back; then
            return
        fi
        if is_dialog_error; then
            dialog --msgbox "Error: Failed to open format selection dialog." 8 60
            return
        fi

        OUTPUT_FORMAT="$DIALOG_RESULT"
        OPTION_STATUS=1

        case "$OUTPUT_FORMAT" in
            "jpeg"|"jpg")
                configure_image_options_jpeg
                OPTION_STATUS=$?
                ;;
            "png")
                configure_image_options_png
                OPTION_STATUS=$?
                ;;
            "webp")
                configure_image_options_webp
                OPTION_STATUS=$?
                ;;
        esac

        if [ "$OPTION_STATUS" -eq 0 ]; then
            break
        fi
        if [ "$OPTION_STATUS" -eq 10 ]; then
            continue
        fi
        return
    done

    if [ "$SAVE_CONFIG" = "1" ]; then
        save_config "IMAGE" "IMAGE_OUTPUT_FORMAT=\"$OUTPUT_FORMAT\"
IMAGE_MAX_RESOLUTION=\"$MAX_RESOLUTION\"
IMAGE_RESIZE_MODE=\"$RESIZE_MODE\"
IMAGE_SCALE_FLAGS=\"$SCALE_FLAGS\"
IMAGE_STRIP_METADATA=\"$STRIP_METADATA\"
IMAGE_OUTPUT_TEMPLATE=\"$OUTPUT_TEMPLATE\"
IMAGE_JPEG_QUALITY=\"${JPEG_QUALITY:-$DEFAULT_JPEG_QUALITY}\"
IMAGE_JPEG_PROGRESSIVE=\"${JPEG_PROGRESSIVE:-$DEFAULT_JPEG_PROGRESSIVE}\"
IMAGE_JPEG_OPTIMIZE=\"${JPEG_OPTIMIZE:-$DEFAULT_JPEG_OPTIMIZE}\"
IMAGE_JPEG_SUBSAMPLING=\"${JPEG_SUBSAMPLING:-$DEFAULT_JPEG_SUBSAMPLING}\"
IMAGE_PNG_COMPRESSION=\"${PNG_COMPRESSION:-$DEFAULT_PNG_COMPRESSION}\"
IMAGE_PNG_PRED=\"${PNG_PRED:-$DEFAULT_PNG_PRED}\"
IMAGE_PNG_PALETTE_MODE=\"${PNG_PALETTE_MODE:-$DEFAULT_PNG_PALETTE_MODE}\"
IMAGE_WEBP_QUALITY=\"${WEBP_QUALITY:-$DEFAULT_WEBP_QUALITY}\"
IMAGE_WEBP_LOSSLESS=\"${WEBP_LOSSLESS:-$DEFAULT_WEBP_LOSSLESS}\"
IMAGE_WEBP_COMPRESSION_LEVEL=\"${WEBP_COMPRESSION_LEVEL:-$DEFAULT_WEBP_COMPRESSION_LEVEL}\"
IMAGE_WEBP_PRESET=\"${WEBP_PRESET:-$DEFAULT_WEBP_PRESET}\"
IMAGE_WEBP_ALPHA_QUALITY=\"${WEBP_ALPHA_QUALITY:-$DEFAULT_WEBP_ALPHA_QUALITY}\""
    fi

    OUTPUT_NAME="$OUTPUT_TEMPLATE"
    OUTPUT_NAME="${OUTPUT_NAME//%name/$NAME}"

    case $OUTPUT_FORMAT in
        "jpeg"|"jpg")
            OUTPUT_NAME="${OUTPUT_NAME//%ext/jpg}"
            ;;
        "png")
            OUTPUT_NAME="${OUTPUT_NAME//%ext/png}"
            ;;
        "webp")
            OUTPUT_NAME="${OUTPUT_NAME//%ext/webp}"
            ;;
        *)
            OUTPUT_NAME="${OUTPUT_NAME//%ext/jpg}"
            OUTPUT_FORMAT="jpeg"
            ;;
    esac

    OUTPUT_FILE="$CURRENT_DIR/$OUTPUT_NAME"
    FILTER_GRAPH=""

    if [ "$MAX_RESOLUTION" != "0" ] && [ -n "$MAX_RESOLUTION" ]; then
        case "$RESIZE_MODE" in
            "fill")
                FILTER_GRAPH="scale=$MAX_RESOLUTION:force_original_aspect_ratio=increase:flags=$SCALE_FLAGS,crop=$MAX_RESOLUTION"
                ;;
            "stretch")
                FILTER_GRAPH="scale=$MAX_RESOLUTION:flags=$SCALE_FLAGS"
                ;;
            *)
                FILTER_GRAPH="scale=$MAX_RESOLUTION:force_original_aspect_ratio=decrease:flags=$SCALE_FLAGS"
                ;;
        esac
    fi

    if [ "$OUTPUT_FORMAT" = "png" ] && [ "${PNG_PALETTE_MODE:-0}" = "1" ]; then
        if [ -n "$FILTER_GRAPH" ]; then
            FILTER_GRAPH="$FILTER_GRAPH,format=pal8"
        else
            FILTER_GRAPH="format=pal8"
        fi
    fi

    FFMPEG_ARGS=(-y -i "$INPUT_FILE")

    if [ -n "$FILTER_GRAPH" ]; then
        FFMPEG_ARGS+=("-vf" "$FILTER_GRAPH")
    fi

    if [ "${STRIP_METADATA:-0}" = "1" ]; then
        FFMPEG_ARGS+=("-map_metadata" "-1")
    fi

    case $OUTPUT_FORMAT in
        "jpeg"|"jpg")
            FFMPEG_ARGS+=("-q:v" "${JPEG_QUALITY:-$DEFAULT_JPEG_QUALITY}")
            if [ "${JPEG_PROGRESSIVE:-0}" = "1" ]; then
                FFMPEG_ARGS+=("-progressive" "1")
            fi
            if [ "${JPEG_OPTIMIZE:-0}" = "1" ]; then
                FFMPEG_ARGS+=("-optimize" "1")
            fi
            case "${JPEG_SUBSAMPLING:-420}" in
                "444") FFMPEG_ARGS+=("-pix_fmt" "yuv444p") ;;
                "422") FFMPEG_ARGS+=("-pix_fmt" "yuv422p") ;;
                *) FFMPEG_ARGS+=("-pix_fmt" "yuv420p") ;;
            esac
            ;;
        "png")
            FFMPEG_ARGS+=("-compression_level" "${PNG_COMPRESSION:-$DEFAULT_PNG_COMPRESSION}" "-pred" "${PNG_PRED:-$DEFAULT_PNG_PRED}")
            ;;
        "webp")
            FFMPEG_ARGS+=("-c:v" "libwebp" "-quality" "${WEBP_QUALITY:-$DEFAULT_WEBP_QUALITY}" "-lossless" "${WEBP_LOSSLESS:-$DEFAULT_WEBP_LOSSLESS}" "-compression_level" "${WEBP_COMPRESSION_LEVEL:-$DEFAULT_WEBP_COMPRESSION_LEVEL}" "-preset" "${WEBP_PRESET:-$DEFAULT_WEBP_PRESET}" "-alpha_quality" "${WEBP_ALPHA_QUALITY:-$DEFAULT_WEBP_ALPHA_QUALITY}")
            ;;
    esac

    FFMPEG_ARGS+=("$OUTPUT_FILE")

    { ffmpeg "${FFMPEG_ARGS[@]}" 2>&1 ; } | dialog --progressbox 30 100

    if [ -f "$OUTPUT_FILE" ]; then
        NEW_SIZE=$(du -h "$OUTPUT_FILE" | cut -f1)
        termux-share -a send "$OUTPUT_FILE"
        dialog --msgbox "Image reduced and shared successfully!\nOriginal: $ORIGINAL_SIZE -> New: $NEW_SIZE\nOutput: $OUTPUT_NAME" 10 60
    else
        dialog --msgbox "Error: Image conversion failed!" 8 40
    fi
}

copy_to_current() {
    if [ "$(dirname "$INPUT_FILE")" = "$CURRENT_DIR" ]; then
        dialog --msgbox "File is already in the current directory!" 8 50
        return
    fi

    DEFAULT_COPY_ACTION="${COPY_ACTION:-copy}"
    COPY_STATE="off"
    MOVE_STATE="off"

    case "$DEFAULT_COPY_ACTION" in
        "move") MOVE_STATE="on" ;;
        *) COPY_STATE="on" ;;
    esac

    while true; do
        run_dialog_capture --clear --backtitle "Copy to Current Folder" \
            --title "Copy Options" \
            --inputbox "Enter target filename:" 10 60 "$BASENAME"
        if is_dialog_back; then
            return
        fi
        if is_dialog_error; then
            dialog --msgbox "Error: Failed to open copy options dialog." 8 60
            return
        fi
        NEW_FILENAME="$DIALOG_RESULT"
        break
    done

    while true; do
        run_dialog_capture --clear --backtitle "Copy to Current Folder" \
            --title "Select Action" \
            --radiolist "Choose copy behavior:" 12 60 2 \
            "copy" "Copy file to current folder" "$COPY_STATE" \
            "move" "Move file to current folder" "$MOVE_STATE"
        if is_dialog_back; then
            return
        fi
        if is_dialog_error; then
            dialog --msgbox "Error: Failed to open copy action dialog." 8 60
            return
        fi
        ACTION="$DIALOG_RESULT"
        break
    done

    if [ "$SAVE_CONFIG" = "1" ]; then
        save_config "COPY" "COPY_ACTION=\"$ACTION\""
    fi
    
    TARGET_FILE="$CURRENT_DIR/$NEW_FILENAME"

    if [ -f "$TARGET_FILE" ]; then
        run_dialog_capture --yesno "File '$NEW_FILENAME' already exists in current directory.\nOverwrite?" 8 60
        if is_dialog_error; then
            dialog --msgbox "Error: Failed to open overwrite confirmation dialog." 8 60
            return
        fi
        if [ "$DIALOG_STATUS" -ne "$DIALOG_OK" ]; then
            return
        fi
    fi

    {
        echo "XXX"
        echo "50"
        if [ "$ACTION" = "move" ]; then
            echo "Moving file..."
        else
            echo "Copying file..."
        fi
        echo "XXX"
        
        if [ "$ACTION" = "move" ]; then
            mv "$INPUT_FILE" "$TARGET_FILE"
        else
            cp "$INPUT_FILE" "$TARGET_FILE"
        fi
        
        echo "XXX"
        echo "100"
        echo "Done!"
        echo "XXX"
    } | dialog --backtitle "Copy to Current Folder" --title "Progress" --gauge "Please wait..." 8 50 0

    if [ -f "$TARGET_FILE" ]; then
        if [ "$ACTION" = "move" ]; then
            dialog --msgbox "File moved successfully to:\n$TARGET_FILE" 8 60
        else
            dialog --msgbox "File copied successfully to:\n$TARGET_FILE" 8 60
        fi
    else
        dialog --msgbox "Error: Failed to $ACTION file!" 8 40
    fi
}

load_config
while true; do
    run_dialog_capture --clear --backtitle "uwu" \
        --title "Main Menu" \
        --menu "What would you like to do with '$BASENAME'?" 15 60 3 \
        1 "Compress to archive and share" \
        2 "Reduce size/resolution (FFmpeg) and share" \
        3 "Copy to current folder"

    if is_dialog_back; then
        clear
        exit 0
    fi
    if is_dialog_error; then
        clear
        dialog --msgbox "Error: Failed to open main menu." 8 50
        exit 1
    fi
    CHOICE="$DIALOG_RESULT"

    case $CHOICE in
        1)
            compress_and_share
            ;;
        2)
            reduce_and_share
            ;;
        3)
            copy_to_current
            ;;
        *)
            clear
            exit 0
            ;;
    esac
done