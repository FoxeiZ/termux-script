#!/data/data/com.termux/files/usr/bin/bash

log_info() {
    printf '[INFO] %s\n' "$*"
}

log_warn() {
    printf '[WARN] %s\n' "$*" >&2
}

usage() {
    printf 'usage: %s <package-filter>\n' "$0" >&2
}

if [ "$#" -ne 1 ]; then
    usage
    exit 2
fi

name_filter="$1"
packages=()

log_info "querying installed packages"
while IFS= read -r line; do
    package_name="${line##*=}"
    if [ -n "$package_name" ] && [ "$package_name" != "$line" ]; then
        packages+=("$package_name")
    fi
done < <(pm list packages -f "$name_filter" 2>/dev/null)

count="${#packages[@]}"
log_info "found ${count} matching package(s)"

if [ "$count" -eq 0 ]; then
    log_warn "no matching package found"
    exit 1
fi

if [ "$count" -eq 1 ]; then
    package_name="${packages[0]}"
else
    printf 'multiple packages found:\n'
    for index in "${!packages[@]}"; do
        printf '%s: %s\n' "$index" "${packages[$index]}"
    done

    while :; do
        printf 'select package index: '
        IFS= read -r choice_raw

        if [[ ! "$choice_raw" =~ ^[0-9]+$ ]]; then
            log_warn "invalid selection: expected an integer index"
            continue
        fi

        if [ "$choice_raw" -ge 0 ] && [ "$choice_raw" -lt "$count" ]; then
            package_name="${packages[$choice_raw]}"
            break
        fi

        log_warn "index out of range; choose 0..$((count - 1))"
    done
fi

log_info "starting package $package_name"
su -c "monkey -p '$package_name' 1" >/dev/null 2>&1
start_code="$?"
if [ "$start_code" -ne 0 ]; then
    log_warn "start command exited with code $start_code"
fi

log_info "disabling auto-rotate"
su -c "settings put system accelerometer_rotation 0"
rotate_code="$?"
if [ "$rotate_code" -ne 0 ]; then
    log_warn "settings command exited with code $rotate_code"
fi

if [ "$start_code" -eq 0 ] && [ "$rotate_code" -eq 0 ]; then
    exit 0
fi

exit 1
