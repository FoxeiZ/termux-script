#!/data/data/com.termux/files/usr/bin/env /data/data/com.termux/files/usr/bin/python

from __future__ import annotations

import argparse
import logging
import subprocess
import sys
from typing import TYPE_CHECKING

if TYPE_CHECKING:
    from collections.abc import Sequence


logging.basicConfig(
    level=logging.INFO,
    format="%(asctime)s | %(levelname)s | %(message)s",
)
LOGGER = logging.getLogger(__name__)


def parse_args(argv: Sequence[str]) -> argparse.Namespace:
    parser = argparse.ArgumentParser(description="Find and launch an Android package via monkey.")
    parser.add_argument("name", help="package name filter")
    return parser.parse_args(argv)


def list_matching_packages(name_filter: str) -> list[str]:
    LOGGER.info("querying installed packages")
    try:
        result = subprocess.run(
            ["pm", "list", "packages", "-f", name_filter],
            check=True,
            capture_output=True,
            text=True,
        )
    except subprocess.CalledProcessError as error:
        LOGGER.error("failed to list packages: %s", error)
        return []

    packages: list[str] = []
    for raw_line in result.stdout.splitlines():
        line = raw_line.strip()
        if not line:
            continue
        if "=" not in line:
            LOGGER.debug("skipping unexpected line: %s", line)
            continue
        _, package_name = line.rsplit("=", maxsplit=1)
        if package_name:
            packages.append(package_name)

    LOGGER.info("found %d matching package(s)", len(packages))
    return packages


def choose_package(packages: list[str]) -> str | None:
    if not packages:
        LOGGER.warning("no matching package found")
        return None

    if len(packages) == 1:
        return packages[0]

    print("multiple packages found:")
    for index, app in enumerate(packages):
        print(f"{index}: {app}")

    while True:
        choice_raw = input("select package index: ").strip()
        if not choice_raw.isdigit():
            LOGGER.warning("invalid selection: expected an integer index")
            continue
        choice = int(choice_raw)
        if 0 <= choice < len(packages):
            return packages[choice]
        LOGGER.warning("index out of range; choose 0..%d", len(packages) - 1)


def run_as_root(command: Sequence[str], suppress_output: bool = False) -> int:
    full_command = ["su", "-c", *command]
    LOGGER.debug("running command: %s", full_command)
    try:
        if suppress_output:
            completed = subprocess.run(
                full_command,
                check=False,
                stdout=subprocess.DEVNULL,
                stderr=subprocess.STDOUT,
            )
        else:
            completed = subprocess.run(full_command, check=False)
    except OSError as error:
        LOGGER.error("failed to execute command: %s", error)
        return 1

    if completed.returncode != 0:
        LOGGER.warning("command exited with code %d", completed.returncode)
    return completed.returncode


def start_package(package_name: str) -> int:
    LOGGER.info("starting package %s", package_name)
    return run_as_root(["monkey", "-p", package_name, "1"], suppress_output=True)


def disable_auto_rotate() -> int:
    LOGGER.info("disabling auto-rotate")
    return run_as_root(["settings", "put", "system", "accelerometer_rotation", "0"])


def main(argv: Sequence[str] | None = None) -> int:
    LOGGER.info("start script execution")
    args = parse_args(sys.argv[1:] if argv is None else argv)
    packages = list_matching_packages(args.name)
    package_name = choose_package(packages)
    if package_name is None:
        return 1

    start_result = start_package(package_name)
    rotate_result = disable_auto_rotate()
    final_code = 0 if (start_result == 0 and rotate_result == 0) else 1
    LOGGER.info("script execution finished with code %d", final_code)
    return final_code


if __name__ == "__main__":
    raise SystemExit(main())
